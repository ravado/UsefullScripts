########################################
# 📂 SMB Server Configuration
########################################
# Full SMB server path to the backup share
SMB_SERVER="//{192.168.91.198/Backups}"

# Subdirectory inside the SMB share to store backups
SMB_SUBDIR="{PhotoFrames}"

########################################
# 🔑 SMB Credentials
########################################
# Samba server user credentials (for server-side restore)
USERNAME="{user}"
PASSWORD="{pass}"

# SMB client credentials (for mounting from this machine)
SMB_CRED_USER="{user}"
SMB_CRED_PASS="{pass}"

########################################
# 🔄 Remote Sync Settings
########################################
# Remote user and host to sync photos from another PicFrame
REMOTE_USER="{user}"
REMOTE_HOST="{ip}"

# Paths for photo synchronization
REMOTE_PATH="{remote_path}"
LOCAL_PATH="{local_path}"